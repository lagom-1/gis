# OpenGIS 环境变量配置
# 复制此文件为 .env 并填入实际值

# ── LLM 配置 ──
LLM_PROVIDER=deepseek          # deepseek 或 tongyi
DEEPSEEK_API_KEY=sk-bfbdf14a76ad4890a8c4316a248a946d       # DeepSeek API Key（deepseek 必填）
DEEPSEEK_MODEL=deepseek-chat   # DeepSeek 模型名
DASHSCOPE_API_KEY=sk-e98a4cc8844246d29c05fa4f1e4b96e6             # 阿里云 DashScope API Key（tongyi 必填）
QWEN_MODEL=qwen-plus          # Qwen 模型名称
LLM_TEMPERATURE=0.1            # LLM 温度

# ── Google Earth Engine ──
EARTHENGINE_PROJECT=ee-819476273           # GEE 项目 ID

# ── 安全 ──
SECRET_KEY=                    # JWT 签名密钥（留空则自动生成随机值）

# ── 数据库 ──
DATABASE_URL=sqlite:///workspace/opengis.db

# ── Redis / Celery ──
REDIS_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── 开发模式 ──
DEV_MODE=true
